# --- Telegram (obligatorio) ---
BOT_TOKEN="123456789:AAExampleTokenReplaceMe"
CHAT_ID="-1001234567890"   # supergroup suele ser -100...

# --- Links /c/... (para botones URL) ---
# Si el grupo es privado (sin @username), los links internos son https://t.me/c/<INTERNAL>/<message_id>
# Sacás <INTERNAL> copiando el link de cualquier mensaje del chat: https://t.me/c/3614790811/12345
TG_INTERNAL_CHAT_ID="3614790811"  # <- este número
# Alternativa: setear directamente la base:
# TG_BASE_MSG_URL="https://t.me/c/3614790811"

# --- Telegram defaults ---
TG_PARSE_MODE="HTML"
TG_DISABLE_WEB_PAGE_PREVIEW="true"

# --- Identidad ---
SERVER_LABEL=""            # default: hostname
BOOT_EMOJI="true"          # true/false
BOOT_ALERTS_ONLY="false"   # true => enviar solo si hay WARN/CRIT o failed units

# --- Thresholds (porcentaje) ---
WARN_LOAD_PCT="70"
CRIT_LOAD_PCT="100"
WARN_RAM_PCT="70"
CRIT_RAM_PCT="85"
WARN_DISK_PCT="70"
CRIT_DISK_PCT="85"

# --- Temperatura (°C) ---
WARN_TEMP_C="70"
CRIT_TEMP_C="85"

# --- Política de notificación ---
BOOT_NOTIFY_POLICY="always"   # always | issues | never

# --- Persistencia de reportes ---
BOOT_REPORT_RETENTION_DAYS="30"
BOOT_REPORT_RETENTION_COUNT="60"
